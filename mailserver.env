OVERRIDE_HOSTNAME=mail.srvrs.top
POSTMASTER_ADDRESS=contact@srvrs.top
ENABLE_SPAMASSASSIN=1
SPAMASSASSIN_SPAM_TO_INBOX=1
ENABLE_CLAMAV=0
ENABLE_FAIL2BAN=1
ENABLE_POSTGREY=0
ENABLE_SASLAUTHD=0
ONE_DIR=1
TLS_LEVEL=modern
SSL_TYPE=manual
SSL_CERT_PATH=/etc/letsencrypt/live/srvrs.top/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/srvrs.top/privkey.pem